DATABASE_URL="file:./dev.db"
UPLOAD_DIR="./uploads"
AUTH_SECRET="change-me-to-a-long-random-secret"
APP_URL="http://localhost:3000"
MAX_UPLOAD_MB="20"
SESSION_DAYS="30"
NODE_ENV="development"
SESSION_COOKIE_SECURE="false"
