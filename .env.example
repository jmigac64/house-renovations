DATABASE_URL="file:./dev.db"
UPLOAD_DIR="./uploads"
AUTH_SECRET="change-me-to-a-long-random-secret"
# Public app URL (supports both https:// and http://).
APP_URL="https://your-domain.example"
MAX_UPLOAD_MB="20"
SESSION_DAYS="30"
NODE_ENV="development"
# Optional override. If unset, cookie security is resolved automatically:
# 1) SESSION_COOKIE_SECURE (if set)
# 2) Request proxy headers (X-Forwarded-Proto / Forwarded)
# 3) APP_URL scheme
# 4) NODE_ENV fallback
# - https:// => secure cookie true
# - http://  => secure cookie false
# SESSION_COOKIE_SECURE="true"
# Optional: set only if you need cookies shared across subdomains
# SESSION_COOKIE_DOMAIN=".example.com"
# Optional: enable structured auth/session debug logs
AUTH_DEBUG="false"
