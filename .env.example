DATABASE_URL="file:./dev.db"
UPLOAD_DIR="./uploads"
AUTH_SECRET="change-me-to-a-long-random-secret"
APP_URL="https://app.example.com"
MAX_UPLOAD_MB="20"
SESSION_DAYS="30"
NODE_ENV="development"
SESSION_COOKIE_SECURE="false"
# Optional: set only if you need cookies on a parent domain (for example .example.com)
# SESSION_COOKIE_DOMAIN=".example.com"
# Optional: enable structured auth/session debug logs
AUTH_DEBUG="false"
